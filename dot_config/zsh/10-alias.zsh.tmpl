# Aliases

# --- ls shortcuts (OS-specific) ---
{{- if eq .chezmoi.os "darwin" }}
alias ll='ls -lGh'
alias la='ls -laGh'
{{- else }}
alias ll='ls -lh --color=auto'
alias la='ls -lah --color=auto'
{{- end }}

# --- git ---
alias g='git'
alias lg='lazygit'

# --- zellij ---
alias zj='zellij'

# --- ruby/bundler ---
alias be='bundle exec'

# --- yazi shell wrapper ---
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  command yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d '' cwd < "$tmp"
  [ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}

# --- ghq + zoxide + fzf (repo selection) ---
repo() {
  local root repo
  root="$(ghq root)" || return

{{- if eq .chezmoi.os "darwin" }}
  repo="$(ghq list | fzf \
    --prompt='ghq> ' \
    --height=40% --reverse \
    --preview="ls -1 '${root}/{}' 2>/dev/null | sed -n '1,200p'")" || return
{{- else }}
  repo="$(ghq list | fzf \
    --prompt='ghq> ' \
    --height=40% --reverse \
    --preview="ls -1 --color=auto '${root}/{}' 2>/dev/null | sed -n '1,200p'")" || return
{{- end }}

  cd "${root}/${repo}" || return

  # zoxide に「よく使うrepo」を学習させる
  zoxide add "${root}/${repo}" >/dev/null 2>&1 || true
}
